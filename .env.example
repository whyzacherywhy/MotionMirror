PORT=4173
NODE_ENV=development

# Postgres connection string from the hosted database provider.
# Example format:
# postgres://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DATABASE_URL=

# Public app URL used for runner invite links after deployment.
# Example: https://your-app.example.com
PUBLIC_APP_URL=http://127.0.0.1:4173

# Set this before real client use. It can be any long random string.
SESSION_SECRET=
